PORT=8080
DATA_DIR=./data
PANDOC_PATH=pandoc
PANDOC_TIMEOUT_SECONDS=300
MAX_UPLOAD_MB=50
TRANSLATION_LAMBDA_URL=
# If TRANSLATION_LAMBDA_URL is empty, the backend calls Bedrock directly (no Lambda needed).
# To use Lambda instead, set the full API Gateway URL above.

# ─── Bedrock direct mode ─────────────────────────────────────────────────────
BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-5-20250929-v1:0
BEDROCK_REGION=us-east-1
# Named AWS profile from ~/.aws/credentials. Leave empty for default credential chain.
BEDROCK_AWS_PROFILE=
TRANSLATION_TIMEOUT_SECONDS=90
GLOSSARY_MAX_TERMS_PER_REQUEST=100
GLOSSARY_MAX_PROMPT_CHARS=12000

# ─── Auth ────────────────────────────────────────────────────────────────────
# Set REQUIRE_AUTH=true in production to enforce Cognito authentication.
# Set REQUIRE_AUTH=false for local development — all requests are treated as
# the DEV_USER_EMAIL identity with admin role, no login required.
REQUIRE_AUTH=false

# Email injected as the authenticated user when REQUIRE_AUTH=false.
DEV_USER_EMAIL=dev@voltdocs.local

# On startup, this email is seeded into user_roles as 'super_admin' (INSERT OR IGNORE).
# Set this to your own email before first run so you can log in as super_admin.
INITIAL_ADMIN_EMAIL=

# ─── Cognito (only needed when REQUIRE_AUTH=true) ────────────────────────────
# The base URL of your Cognito User Pool domain (no trailing slash).
COGNITO_DOMAIN=https://voltdocs.auth.us-east-1.amazoncognito.com

# App client ID from the Cognito User Pool → App clients page.
COGNITO_CLIENT_ID=2fnmsk89dt0066l25kmi68m7qp

# App client secret (leave empty if the client has no secret).
COGNITO_CLIENT_SECRET=

# Must match the callback URL configured in the Cognito app client settings.
COGNITO_REDIRECT_URI=http://localhost:8080/api/auth/callback
