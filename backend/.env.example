# ===== 服务器配置 =====
PORT=8080
DATA_DIR=./data
MAX_UPLOAD_MB=50

# ===== Pandoc (Markdown 转 Word) =====
PANDOC_PATH=pandoc
PANDOC_TIMEOUT_SECONDS=300

# ===== 翻译配置 =====
TRANSLATION_BATCH_MAX_BYTES=5000
TRANSLATION_BATCH_MAX_SEGMENTS=40
TRANSLATION_TIMEOUT_SECONDS=90

# ===== Bedrock 配置 =====
BEDROCK_MODEL_ID=us.amazon.nova-lite-v1:0
BEDROCK_REGION=us-east-1
# Named profile from ~/.aws/credentials; leave empty for default credential chain.
BEDROCK_AWS_PROFILE=

# ===== 术语表提示词限制 =====
GLOSSARY_MAX_TERMS_PER_REQUEST=100
GLOSSARY_MAX_PROMPT_CHARS=12000

# ===== QA / AI 修复 =====
QA_AI_ENABLED=true
QA_AI_MODEL_ID=us.amazon.nova-micro-v1:0
QA_AI_UNCERTAIN_THRESHOLD=0.75
QA_AI_BATCH_MAX_SEGMENTS=40
QA_REPAIR_ENABLED=true
QA_REPAIR_MAX_ATTEMPTS=1
QA_REPAIR_BATCH_MAX_SEGMENTS=40
TM_WEAK_AI_ENABLED=false

# ===== 认证 (Cognito) =====
# REQUIRE_AUTH=false: local dev, all requests use DEV_USER_EMAIL as super_admin.
REQUIRE_AUTH=false
DEV_USER_EMAIL=dev@voltdocs.local
INITIAL_ADMIN_EMAIL=

COGNITO_DOMAIN=https://your-domain.auth.us-east-1.amazoncognito.com
COGNITO_CLIENT_ID=your-cognito-client-id
COGNITO_CLIENT_SECRET=
COGNITO_REDIRECT_URI=http://localhost:5173/api/auth/callback
FRONTEND_URL=http://localhost:5173
